10.Non-Sharable 1st Fit 
#include <stdio.h>
int main(){
    int b[5]={100,500,200,300,600};
    int p[4]={212,417,112,426};
    int alloc[4]={0};
    int used=0;
    printf("Non-Shareable 1st Fit\n");
    printf("Total Available Memory=1700 KB\n\n");
    for(int i=0;i<4;i++){
        for(int j=0;j<5;j++){
            if(b[j]>=p[i]){
                printf("P%d(%d KB)->Allocated in %d KB block\n",i+1,p[i],b[j]);
                used+=p[i];
                b[j]=0;
                alloc[i]=1;
                break;
            }
        }
        if(!alloc[i])
            printf("P%d(%d KB)->Not Allocated\n",i+1,p[i]);
    }
    printf("\nTotal Used Memory=%d KB\n",used);
    printf("Total Unused Memory=%d KB",1700-used);
}



