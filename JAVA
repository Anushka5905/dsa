4.a Division by 7
class DivisibleBy 7 {
    public static void main(String[] args) {
        int count = 0, sum = 0;

        for(int i = 101; i < 200; i++) {
            if(i % 7 == 0) {
                count++;
                sum += i;
            }
        }

        System.out.println("Count = " + count);
        System.out.println("Sum = " + sum);
    }
