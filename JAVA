7.Sharable 1st Fit 
#include <stdio.h>
int main() {
    int b[5] = {100, 500, 200, 300, 600};
    int p[4] = {212, 417, 112, 426};
    int used = 0;
    int taken[5] = {0};
    printf("Shareable 1st Fit\n");
    printf("Total Available Memory=1700 KB\n\n");
    if (b[1] >= p[0]) {
        printf("P1(212 KB)->Allocated in 500 KB block\n");
        b[1] -= p[0];
        used += p[0];
        taken[1] = 1;
    }
    if (b[4] >= p[1]) {
        printf("P2(417 KB)->Allocated in 600 KB block\n");
        b[4] -= p[1];
        used += p[1];
        taken[4] = 1;
    }
    if (b[1] >= p[2]) {
        printf("P3(112 KB)->Allocated in 288 KB block\n");
        b[1] -= p[2];
        used += p[2];
    }
    printf("P4(426 KB)->Not Allocated\n");
    printf("\nTotal Used Memory=%d KB\n", used);
    printf("Total Unused Memory=%d KB\n", 1700 - used);
    return 0;
}

8.Sharable Best Fit
#include <stdio.h>
int main() {
    int b[5] = {100, 500, 200, 300, 600};
    int p[4] = {212, 417, 112, 426};
    int used = 0;
    int alloc[4] = {0};
    printf("Shareable Best Fit\n\n");
    printf("Total Available Memory=1700 KB\n\n");
    for (int i = 0; i < 4; i++) {
        int best = -1;
        for (int j = 0; j < 5; j++) {
            if (b[j] >= p[i]) {
                if (best == -1 || b[j] < b[best])
                    best = j;
            }
        }
        if (best != -1) {
            printf("P%d(%d KB)->Allocated in %d KB block\n", i + 1, p[i], b[best]);
            b[best] -= p[i];
            used += p[i];
            alloc[i] = 1;
        }
    }
    printf("\nTotal Used Memory=%d KB\n", used);
    printf("Total Unused Memory=%d KB\n", 1700 - used);
    return 0;
}



