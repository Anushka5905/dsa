2.a Prime NO.
import java.util.*;

class Prime {
    public static void main(String[] args) {
        int n, i, flag = 0;
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter number: ");
        n = sc.nextInt();

        for(i = 2; i <= n/2; i++) {
            if(n % i == 0) {
                flag = 1;
                break;
            }
        }

        if(flag == 0 && n > 1)
            System.out.println("Prime");
        else
            System.out.println("Not Prime");
    }
}

2.b palindrom
import java.util.*;

class Palindrome {
    public static void main(String[] args) {
        int n, rev = 0, temp;
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter number: ");
        n = sc.nextInt();
        temp = n;

        while(n > 0) {
            int d = n % 10;
            rev = rev * 10 + d;
            n = n / 10;
        }

        if(temp == rev)
            System.out.println("Palindrome");
        else
            System.out.println("Not Palindrome");
    }
}


