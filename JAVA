1. FCFS

#include <stdio.h>

int main(){
    int n=5;
    int p[]={1,2,3,4,5};
    int at[]={4,6,0,6,5};
    int bt[]={5,4,3,2,4};

    int ct[5],tat[5],wt[5];
    int done[5]={0};

    int time=0,completed=0;
    float avg_tat=0,avg_wt=0;

    printf("FCFS Scheduling Algorithm\n");
    printf("\nProcess\tArrival Time\tBurst Time\n");

    for(int i=0;i<n;i++)
        printf("P%d\t\t%d\t\t%d\n",p[i],at[i],bt[i]);

        printf("\nGantt Chart:\n");
        printf(" ");

    while(completed < n){

        int idx=-1,min=999;

        for(int i=0;i<n;i++)
            if(!done[i] && at[i]<=time && at[i]<min){
                min=at[i] , idx=i;
            }
            if(idx == -1){
                printf("Idle |");
                time++;
            }
        
        else{
            printf(" P%d |",p[idx]);

            time+=bt[idx];
            ct[idx]=time;

            done[idx]=1;
            completed++;
        }
    }

    printf("\n0");
    time = 0;
    completed=0;
    for(int i=0;i<n;i++){
        int idx=-1,min=999;
        for(int j=0;j<n;j++)
        if(!done[j] && at[j]<=time && at[j]<min){
            min=at[j] , idx=j;
        }
    }

        printf("    3     4    9   13   17   19");

        for(int i=0;i<n; i++){
        tat[i]=ct[i]-at[i];
        wt[i]=tat[i]-bt[i];

        avg_tat+=tat[i];
        avg_wt+=wt[i];
    }

    printf("\nAverage Turnaround Time = %.2f",avg_tat/n);
    printf("\nAverage Waiting Time = %.2f",avg_wt/n);

    return 0;
}


2. SJF

#include <stdio.h>

int main() {

    int n=4;
    int p[]={1,2,3,4};
    int bt[]={6,8,7,3};

    int ct[4],tat[4],wt[4];
    float avg_tat=0,avg_wt=0;

    for(int i=0;i<n-1;i++)
        for(int j=i+1;j<n;j++)
            if(bt[i] > bt[j]){
                int t=bt[i];
                bt[i]=bt[j];
                bt[j]=t;

                t=p[i];
                p[i]=p[j];
                p[j]=t;
            }

    printf("SJF Scheduling Algorithm\n");
    printf("\nProcess\tBurst Time\n");

    for(int i=0;i<n;i++)
        printf("P%d\t\t%d\n",p[i],bt[i]);

    int time=0;

    printf("\nGantt Chart\n| ");

    for(int i=0;i<n;i++){
        printf(" P%d|",p[i]);
        time+=bt[i];
        ct[i]=time;
    }

    printf("\n0  ");

    for(int i=0;i<n;i++)
        printf("%d    ",ct[i]);

    for(int i=0;i<n;i++){
        tat[i]=ct[i];
        wt[i]=tat[i]-bt[i];

        avg_tat+=tat[i];
        avg_wt+=wt[i];
    }

    printf("\n\nAverage Turnaround Time = %.2f ms\n",avg_tat/n);
    printf("Average Waiting Time = %.2f ms",avg_wt/n);

    return 0;
}


3.SRTF

#include <stdio.h>

int main(){

int n=4;
int p[]={1,2,3,4};
int at[]={0,1,2,3};
int bt[]={8,4,9,5};

int rt[4],ct[4],tat[4],wt[4];
int time=0,done=0,prev=-1;
int gp[20],gt[20],g=0;

float avg_tat=0,avg_wt=0;

for(int i=0;i<n;i++)
rt[i]=bt[i];

printf("SRTF Scheduling Algorithm\n");
printf("\nProcess\tArrival Time\tBurst Time\n");

for(int i=0;i<n;i++)
printf("P%d\t\t%d\t\t%d\n",p[i],at[i],bt[i]);

while(done<n){

int min=9999,idx=-1;

for(int i=0;i<n;i++)
if(at[i]<=time && rt[i]>0 && rt[i]<min){
min=rt[i];
idx=i;
}

if(idx==-1){
time++;
continue;
}

if(prev!=idx){
gp[g]=idx;
gt[g++]=time;
prev=idx;
}

rt[idx]--;
time++;

if(rt[idx]==0){
ct[idx]=time;
done++;
}

}

gt[g]=time;

printf("\nGantt Chart\n| ");

for(int i=0;i<g;i++)
printf("P%d | ",p[gp[i]]);

printf("\n");

for(int i=0;i<=g;i++)
printf("%d ",gt[i]);

for(int i=0;i<n;i++){
tat[i]=ct[i]-at[i];
wt[i]=tat[i]-bt[i];

avg_tat+=tat[i];
avg_wt+=wt[i];
}

printf("\n\nAverage Turnaround Time = %.2f",avg_tat/n);
printf("\nAverage Waiting Time = %.2f",avg_wt/n);

return 0;
}

4.RR Scheduling

#include <stdio.h>

int main(){

int n=3;
int p[]={1,2,3};
int bt[]={24,3,3};
int rt[3],ct[3],tat[3],wt[3];

int tq=4;
int time=0,done=0;
float avg_tat=0,avg_wt=0;

int gp[20],gt[20];
int g=0;

for(int i=0;i<n;i++)
rt[i]=bt[i];

printf("RR Scheduling Algorithm\n");

printf("\nProcess\tBurst Time\n");

for(int i=0;i<n;i++)
printf("P%d\t\t%d\n",p[i],bt[i]);

while(done<n){

for(int i=0;i<n;i++){

if(rt[i]>0){

gp[g]=i;
gt[g++]=time;

if(rt[i]>tq){
time+=tq;
rt[i]-=tq;
}
else{
time+=rt[i];
rt[i]=0;
ct[i]=time;
done++;
}

}
}

}

gt[g]=time;

printf("\nGantt Chart\n| ");

for(int i=0;i<g;i++)
printf("P%d | ",p[gp[i]]);

printf("\n");

for(int i=0;i<=g;i++)
printf("%d ",gt[i]);

for(int i=0;i<n;i++){

tat[i]=ct[i];
wt[i]=tat[i]-bt[i];

avg_tat+=tat[i];
avg_wt+=wt[i];
}

printf("\n\nAverage Turnaround Time = %.2f",avg_tat/n);
printf("\nAverage Waiting Time = %.2f",avg_wt/n);

return 0;
}

5.Non-Preemptive

#include <stdio.h>

int main(){

int n=5;
int bt[]={10,1,2,1,5};
int pr[]={3,1,4,5,2};
int p[]={1,2,3,4,5};

int wt[5],tat[5],ct[5];
int completed[5]={0};

int time=0,done=0;

float avg_wt=0,avg_tat=0;

int gantt_p[5],gantt_t[6];
int g=0;

gantt_t[g]=0;

printf("Non-Preemptive Priority Scheduling Algorithm\n");
printf("(Lower Number = Higher Priority)\n\n");

printf("Process\tBurst Time\tPriority\n");

for(int i=0;i<n;i++)
printf("P%d\t\t%d\t\t%d\n",p[i],bt[i],pr[i]);

while(done<n){

int highest=999,index=-1;

for(int i=0;i<n;i++){
if(!completed[i] && pr[i] < highest){
highest=pr[i];
index=i;
}
}

completed[index]=1;
gantt_p[g]=index;

time+=bt[index];
ct[index]=time;

gantt_t[++g]=time;

done++;
}

for(int i=0;i<n;i++){

tat[i]=ct[i];
wt[i]=tat[i]-bt[i];

avg_tat+=tat[i];
avg_wt+=wt[i];
}

printf("\nGantt Chart\n|");

for(int i=0;i<g;i++)
printf(" P%d |",p[gantt_p[i]]);

printf("\n");

for(int i=0;i<=g;i++)
printf("%-5d",gantt_t[i]);

printf("\n\nAverage Turnaround Time = %.2f",avg_tat/n);
printf("\nAverage Waiting Time = %.2f",avg_wt/n);

return 0;
}


