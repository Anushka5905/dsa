1.Linear Search

#include <stdio.h>
#include <time.h>

int main() {
    int a[100], n, key, i, found = 0;
    clock_t start, end;

    printf("Enter n: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    printf("Enter key: ");
    scanf("%d", &key);

    start = clock();

    for(i = 0; i < n; i++) {
        if(a[i] == key) {
            found = 1;
            break;
        }
    }

    end = clock();

    if(found)
        printf("Found at position %d\n", i+1);
    else
        printf("Not found\n");

    printf("CPU Time: %lf\n", (double)(end - start)/CLOCKS_PER_SEC);
}



2.Binary Search
#include <stdio.h>
#include <time.h>

int main() {
    int a[100], n, key, low, high, mid, found = 0;
    clock_t start, end;

    scanf("%d", &n);
    for(int i=0;i<n;i++) scanf("%d",&a[i]);

    scanf("%d",&key);

    low = 0; high = n-1;

    start = clock();

    while(low <= high) {
        mid = (low + high)/2;
        if(a[mid] == key) {
            found = 1;
            break;
        }
        else if(key < a[mid])
            high = mid - 1;
        else
            low = mid + 1;
    }

    end = clock();

    if(found) printf("Found\n");
    else printf("Not Found\n");

    printf("CPU Time: %lf\n",(double)(end-start)/CLOCKS_PER_SEC);
}


3.MergeSort
#include <stdio.h>
#include <time.h>

void merge(int a[], int l, int m, int r) {
    int i=l, j=m+1, k=0, temp[100];

    while(i<=m && j<=r)
        temp[k++] = (a[i] < a[j]) ? a[i++] : a[j++];

    while(i<=m) temp[k++] = a[i++];
    while(j<=r) temp[k++] = a[j++];

    for(i=l, k=0; i<=r; i++,k++)
        a[i] = temp[k];
}

void mergesort(int a[], int l, int r) {
    if(l < r) {
        int m = (l+r)/2;
        mergesort(a,l,m);
        mergesort(a,m+1,r);
        merge(a,l,m,r);
    }
}

int main() {
    int a[100], n;
    clock_t start, end;

    scanf("%d",&n);
    for(int i=0;i<n;i++) scanf("%d",&a[i]);

    start = clock();
    mergesort(a,0,n-1);
    end = clock();

    for(int i=0;i<n;i++) printf("%d ",a[i]);

    printf("\nCPU Time: %lf\n",(double)(end-start)/CLOCKS_PER_SEC);
}


4.Knapsack
#include <stdio.h>
#include <time.h>

int main() {
    int n, w[10], p[10], i, j, capacity;
    float ratio[10], total = 0;

    clock_t start, end;

    scanf("%d",&n);
    for(i=0;i<n;i++) {
        scanf("%d%d",&w[i],&p[i]);
        ratio[i] = (float)p[i]/w[i];
    }

    scanf("%d",&capacity);

    start = clock();

    for(i=0;i<n-1;i++)
        for(j=i+1;j<n;j++)
            if(ratio[i] < ratio[j]) {
                float temp = ratio[i]; ratio[i]=ratio[j]; ratio[j]=temp;
                int t=w[i]; w[i]=w[j]; w[j]=t;
                t=p[i]; p[i]=p[j]; p[j]=t;
            }

    for(i=0;i<n;i++) {
        if(capacity >= w[i]) {
            total += p[i];
            capacity -= w[i];
        } else {
            total += ratio[i]*capacity;
            break;
        }
    }

    end = clock();

    printf("Max Profit: %f\n", total);
    printf("CPU Time: %lf\n",(double)(end-start)/CLOCKS_PER_SEC);
}


5.Job Sequencing
#include <stdio.h>
#include <time.h>

int main() {
    int n, profit[10], deadline[10], slot[10]={0};
    int i,j, total=0;

    clock_t start, end;

    scanf("%d",&n);
    for(i=0;i<n;i++)
        scanf("%d%d",&profit[i],&deadline[i]);

    start = clock();

    for(i=0;i<n-1;i++)
        for(j=i+1;j<n;j++)
            if(profit[i] < profit[j]) {
                int t=profit[i]; profit[i]=profit[j]; profit[j]=t;
                t=deadline[i]; deadline[i]=deadline[j]; deadline[j]=t;
            }

    for(i=0;i<n;i++)
        for(j=deadline[i]-1;j>=0;j--)
            if(slot[j]==0) {
                slot[j]=1;
                total += profit[i];
                break;
            }

    end = clock();

    printf("Max Profit: %d\n", total);
    printf("CPU Time: %lf\n",(double)(end-start)/CLOCKS_PER_SEC);
}


6.Prims 
#include <stdio.h>
#include <limits.h>
#include <time.h>

int main() {
    int n, cost[10][10], visited[10]={0};
    int min, x=0,y=0, total=0;

    clock_t start,end;

    scanf("%d",&n);
    for(int i=0;i<n;i++)
        for(int j=0;j<n;j++)
            scanf("%d",&cost[i][j]);

    visited[0]=1;

    start = clock();

    for(int k=0;k<n-1;k++) {
        min = INT_MAX;
        for(int i=0;i<n;i++)
            for(int j=0;j<n;j++)
                if(visited[i] && !visited[j] && cost[i][j] < min) {
                    min = cost[i][j];
                    x=i; y=j;
                }

        visited[y]=1;
        total += min;
    }

    end = clock();

    printf("Cost: %d\n",total);
    printf("CPU Time: %lf\n",(double)(end-start)/CLOCKS_PER_SEC);
}

7.Kruskals
#include <stdio.h>
#include <time.h>

int parent[10];

int find(int i) {
    while(parent[i]) i=parent[i];
    return i;
}

void union1(int i,int j) {
    parent[j]=i;
}

int main() {
    int n, cost[10][10], min, total=0;
    clock_t start,end;

    scanf("%d",&n);
    for(int i=0;i<n;i++)
        for(int j=0;j<n;j++)
            scanf("%d",&cost[i][j]);

    start = clock();

    for(int k=0;k<n-1;k++) {
        min=999;
        int a=-1,b=-1;

        for(int i=0;i<n;i++)
            for(int j=0;j<n;j++)
                if(cost[i][j] < min) {
                    min = cost[i][j];
                    a=i; b=j;
                }

        int u=find(a), v=find(b);

        if(u!=v) {
            union1(u,v);
            total += min;
        }

        cost[a][b]=cost[b][a]=999;
    }

    end = clock();

    printf("Cost: %d\n",total);
    printf("CPU Time: %lf\n",(double)(end-start)/CLOCKS_PER_SEC);
}


8.Multistage graph
#include <stdio.h>
#include <limits.h>
#include <time.h>

int main() {
    int n, cost[10][10], dist[10];
    clock_t start,end;

    scanf("%d",&n);
    for(int i=0;i<n;i++)
        for(int j=0;j<n;j++)
            scanf("%d",&cost[i][j]);

    start = clock();

    dist[n-1] = 0;

    for(int i=n-2;i>=0;i--) {
        dist[i] = INT_MAX;
        for(int j=i+1;j<n;j++)
            if(cost[i][j] && dist[i] > cost[i][j]+dist[j])
                dist[i] = cost[i][j]+dist[j];
    }

    end = clock();

    printf("Min Cost: %d\n",dist[0]);
    printf("CPU Time: %lf\n",(double)(end-start)/CLOCKS_PER_SEC);
}


9.TSP
#include <stdio.h>
#include <limits.h>
#include <time.h>

int main() {
    int n, cost[10][10], visited[10]={0};
    int i, j, min, total=0, city=0;

    clock_t start,end;

    scanf("%d",&n);
    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&cost[i][j]);

    visited[0]=1;

    start = clock();

    for(i=0;i<n-1;i++) {
        min = INT_MAX;
        for(j=0;j<n;j++)
            if(!visited[j] && cost[city][j] < min) {
                min = cost[city][j];
                city = j;
            }
        visited[city]=1;
        total += min;
    }

    end = clock();

    printf("Cost: %d\n",total);
    printf("CPU Time: %lf\n",(double)(end-start)/CLOCKS_PER_SEC);
}
